# Copy this file to `spark-etl/.env` and update the values for your machine.

# Target database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=target_analytics
MYSQL_USER=mysql_user
MYSQL_PASSWORD=another_secure_password

# Shared SQL Server settings used by the control-table ETL
SQLSERVER_SOURCE_DATABASE=source_warehouse
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_COMMON_DATABASE=mStudioCommon
SQLSERVER_BILLING_DATABASE=mStudioBilling
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=StrongP@ssword
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_SERVER_CERTIFICATE=true
